#!/usr/bin/env bash
set -euxo pipefail

# # Step 0: Load environment and libraries
# Rscript 00_env_library_loading.R "$@"

# Helper: render an R script to HTML via knitr::spin and save to /results/
render_html() {
  local script="$1"
  local outname
  outname="$(basename "${script%.R}").html"
  Rscript -e "
    rmd <- knitr::spin('$script', knit = FALSE, format = 'Rmd')
    rmarkdown::render(rmd, output_format = 'html_document',
                      output_file = '$outname', output_dir = '/results/')
    file.remove(rmd)
  "
}

# Step 1a: Convert Brain 3 .mat to .rds
render_html 01_BarSeq_RDSconvert_brain3_v2.R

# Step 1b: Convert Brain 4 .mat to .rds
render_html 01_BarSeq_RDSconvert_brain4_v2.R

# Step 2: TEMPORARY -- validate output against the previously-published reference asset.
# Remove this step (and the reference asset attachment) before final release.
# Plain text output (not HTML) since this is an ephemeral diagnostic.
Rscript 02_validate_against_reference.R > /results/02_validate_against_reference.txt 2>&1 || true

echo "=== Reproducible Run complete. HTML reports and results saved to /results/ ==="
#!/usr/bin/env bash
set -e
mamba install -y r-base=4.2.3
wget https://www.python.org/ftp/python/3.7.12/Python-3.7.12.tgz \
    && tar xvf Python-3.7.12.tgz \
    && cd Python-3.7.12 \
    && ./configure --enable-shared \
    && make install \
    && cd ..
wget https://www.python.org/ftp/python/3.12.0/Python-3.12.0.tgz \
    && tar xvf Python-3.12.0.tgz \
    && cd Python-3.12.0 \
    && ./configure --enable-shared \
    && make install
mamba remove -n barseq-r4 --all && mamba remove -n r4-base --all && for f in /etc/mamba-envs/*.yml; do mamba env create -f "$f"; done
mamba install -n r4-base -c conda-forge r-clustree 
mamba install -n barseq-r4 -c conda-forge r-clustree r-reticulate=1.28 r-seurat
Rscript -e '.libPaths("/opt/conda/envs/r4-base/lib/R/library/");install.packages("Matrix");install.packages("SeuratObject");devtools::install_github("satijalab/seurat-data")'
Rscript -e '.libPaths("/opt/conda/envs/barseq-r4/lib/R/library/");install.packages("Matrix");install.packages("SeuratObject");devtools::install_github("satijalab/seurat-data")'
mamba install -n r4-base -c conda-forge -c bioconda r-ape r-umap bioconductor-metaneighbor bioconductor-summarizedexperiment